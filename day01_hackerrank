📁 9) Weather Observation Station 3
            -- Problem: Weather Observation Station 3
            
            -- Approach:
            -- 1. Select DISTINCT CITY
            -- 2. Filter even ID using MOD
            
            SELECT DISTINCT CITY
            FROM STATION
            WHERE MOD(ID, 2) = 0;
            
            -- Key Learning:
            -- DISTINCT + MOD for even numbers
📁 10) Weather Observation Station 4
            -- Problem: Weather Observation Station 4
            
            -- Approach:
            -- 1. Count total CITY
            -- 2. Count distinct CITY
            -- 3. Subtract to get duplicates
            
            SELECT COUNT(CITY) - COUNT(DISTINCT CITY)
            FROM STATION;
            
            -- Key Learning:
            -- COUNT vs DISTINCT
