📁 1) Weather Observation Station 5
      -- Problem: Weather Observation Station 5
      
      -- Approach:
      -- 1. Find city with shortest and longest name
      -- 2. Use LENGTH() to calculate length
      -- 3. Order by length and pick first row

        (SELECT CITY, LENGTH(CITY)
         FROM STATION
         ORDER BY LENGTH(CITY), CITY
         LIMIT 1)
        
        UNION
        
        (SELECT CITY, LENGTH(CITY)
         FROM STATION
         ORDER BY LENGTH(CITY) DESC, CITY
         LIMIT 1);
        
        -- Key Learning:
        -- Learned LENGTH(), ORDER BY, LIMIT and UNION
📁 2) Revising the Select Query
            -- Problem: Revising the Select Query
            
            -- Approach:
            -- 1. Select all columns
            -- 2. Filter only USA cities
            -- 3. Population > 100000
            
            SELECT *
            FROM CITY
            WHERE COUNTRYCODE = 'USA'
            AND POPULATION > 100000;
            
            -- Key Learning:
            -- WHERE with AND condition
📁 3) Revising the Select Query 2
          -- Problem: Revising the Select Query II
          
          -- Approach:
          -- 1. Select only NAME column
          -- 2. Apply same conditions
          
          SELECT NAME
          FROM CITY
          WHERE COUNTRYCODE = 'USA'
          AND POPULATION > 120000;
          
          -- Key Learning:
          -- Selecting specific columns
